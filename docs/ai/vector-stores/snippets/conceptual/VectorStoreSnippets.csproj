    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS8019;CS0219;CS1591;CS8602</NoWarn>
  </PropertyGroup>

  <ItemGroup>
